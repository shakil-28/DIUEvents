# 🔒 Firebase Configuration
# Copy this file to .env and replace with your actual Firebase keys.
# DO NOT commit .env to version control!
# Get keys from: https://console.firebase.google.com/project/<your-project>/settings/general

# Firebase Web API Key
FIREBASE_WEB_API_KEY=your_web_api_key_here
FIREBASE_WEB_APP_ID=your_web_app_id_here
FIREBASE_WEB_MESSAGING_SENDER_ID=your_web_sender_id_here
FIREBASE_WEB_MEASUREMENT_ID=your_measurement_id_here

# Firebase Android API Key
FIREBASE_ANDROID_API_KEY=your_android_api_key_here
FIREBASE_ANDROID_APP_ID=your_android_app_id_here

# Firebase iOS/macOS API Key
FIREBASE_IOS_API_KEY=your_ios_api_key_here
FIREBASE_IOS_APP_ID=your_ios_app_id_here
FIREBASE_IOS_BUNDLE_ID=com.yourapp.bundleid

# Common
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_bucket.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
